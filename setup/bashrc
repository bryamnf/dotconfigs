#!/bin/bash

##########Interactive shell#############
if  echo $- | grep -q "i"; then

	######Local binaries in path######
	export PATH="$HOME/.local/bin:$PATH"
	echo "[bashrc-log] ~/.local/bin in PATH"

	#######ibashrc set up###########
	if [ -f "$HOME/.ibashrc" ]; then
		source "$HOME/.ibashrc"
    		echo "[bashrc-log] Using dotconfigs in interactive shell mode!"
	fi
	
	########Pixi set up############
	if [ -x "$HOME/.pixi/bin/pixi" ]; then		
		export PATH="$HOME/.pixi/bin:$PATH"
		eval "$(pixi completion --shell bash)"
		echo "[bashrc-log] Using pixi as pkg manager!"
		
		if [ -x $HOME/.pixi/bin/uv ] && [ -x $HOME/.pixi/bin/uvx ]; then 
			eval "$(uv generate-shell-completion bash)"
			eval "$(uvx --generate-shell-completion bash)"
			echo "[bashrc-log] uv and uvx installed and sourced!"
		else
			echo "[bashrc-log] uv and uvx are not intalled!"
		fi
	fi
else
##########Non-interactive shell#############
	if [ -d $HOME/.local/bin ] && [ -x "$HOME/.pixi/bin/pixi" ]; then
		######Local binaries in path######
		export PATH="$HOME/.local/bin:$PATH"
		########Pixi set up############
		export PATH="$HOME/.pixi/bin:$PATH"
	fi
fi

