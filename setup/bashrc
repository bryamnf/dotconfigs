#!/bin/bash

#######Bashrc set up###########
if [ -f "$HOME/.ibashrc" ]; then
	if  echo $- | grep -q "i"; then
		source "$HOME/.ibashrc"
    		echo "Using dotconfigs in interactive shell mode!"
	fi
fi

########Pixi set up############
if [ -d "$HOME/.pixi" ]; then
	export PATH="$HOME/.pixi/bin:$PATH"
	eval "$(pixi completion --shell bash)"
	echo "Using pixi as pkg manager"
fi 
