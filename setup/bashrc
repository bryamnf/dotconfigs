#!/bin/bash

##########Interactive shell#############
if echo $- | grep -q "i"; then

    _log_ok=""
    _log_warn=""

    ######Local binaries in path######
    export PATH="$HOME/.local/bin:$PATH"

    #######ibashrc set up###########
    if [ -f "$HOME/.ibashrc" ]; then
        source "$HOME/.ibashrc"
        _log_ok="$_log_ok ibashrc,"
    else
        _log_warn="$_log_warn [!] ~/.ibashrc not found"
    fi

    ########Pixi set up############
    if [ -x "$HOME/.pixi/bin/pixi" ]; then
        export PATH="$HOME/.pixi/bin:$PATH"
        eval "$(pixi completion --shell bash)"
        _log_ok="$_log_ok pixi,"

        if [ -x "$HOME/.pixi/bin/uv" ] && [ -x "$HOME/.pixi/bin/uvx" ]; then
            eval "$(uv generate-shell-completion bash)"
            eval "$(uvx --generate-shell-completion bash)"
            _log_ok="$_log_ok uv/uvx,"
        else
            _log_warn="$_log_warn [!] uv/uvx not installed"
        fi
    else
        _log_warn="$_log_warn [!] pixi not found"
    fi

    #########nvm and npm set up###########
    if [ -d "$HOME/.npm" ] && [ -d "$HOME/.nvm" ]; then
        export NVM_DIR="$HOME/.nvm"
        [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
        eval "$(npm completion)"
        _log_ok="$_log_ok nvm/npm,"
    else
        _log_warn="$_log_warn  [!] nvm/npm not found"
    fi

    #########cargo/rust set up###########
    if [ -d "$HOME/.cargo" ]; then
        . "$HOME/.cargo/env"
        eval "$(rustup completions bash)"
        eval "$(rustup completions bash cargo)"
        if [ -x "$HOME/.cargo/bin/zoxide" ]; then
            eval "$(zoxide init bash --cmd cd)"
            _log_ok="$_log_ok rust/cargo/zoxide!"
        else
            _log_ok="$_log_ok rust/cargo!"
        fi
    else
        _log_warn="$_log_warn  [!] cargo/rust not found"
    fi

    # Summary
    if [ -z "$_log_warn" ]; then
        echo "[bashrc] OK: $_log_ok"
    else
        echo "[bashrc] loaded: $_log_ok" 
        echo "[bashrc] warning: $_log_warn"
    fi

    unset _log_ok _log_warn

##########Non-interactive shell#############
else
    [ -d "$HOME/.local/bin" ]       && export PATH="$HOME/.local/bin:$PATH"
    [ -x "$HOME/.pixi/bin/pixi" ]   && export PATH="$HOME/.pixi/bin:$PATH"
    [ -d "$HOME/.cargo" ]           && . "$HOME/.cargo/env"

    if [ -d "$HOME/.nvm" ]; then
        export NVM_DIR="$HOME/.nvm"
        [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    fi
fi
